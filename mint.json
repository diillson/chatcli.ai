{
  "$schema": "https://mintlify.com/schema.json",
  "name": "ChatCLI",
  "logo": {
    "dark": "/images/logo-dark.svg",
    "light": "/images/logo-light.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1E40AF",
    "anchors": {
      "from": "#2563EB",
      "to": "#7C3AED"
    }
  },
  "topbarLinks": [
    {
      "name": "GitHub",
      "url": "https://github.com/diillson/chatcli"
    }
  ],
  "topbarCtaButton": {
    "name": "Instalar",
    "url": "https://github.com/diillson/chatcli/releases"
  },
  "tabs": [
    {
      "name": "Cookbook",
      "url": "cookbook"
    },
    {
      "name": "Referência",
      "url": "reference"
    }
  ],
  "anchors": [
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/diillson/chatcli"
    },
    {
      "name": "Issues",
      "icon": "bug",
      "url": "https://github.com/diillson/chatcli/issues"
    }
  ],
  "navigation": [
    {
      "group": "Início",
      "pages": [
        "introduction"
      ]
    },
    {
      "group": "Primeiros Passos",
      "pages": [
        "getting-started/installation",
        "getting-started/docker-deployment"
      ]
    },
    {
      "group": "Conceitos Fundamentais",
      "pages": [
        "core-concepts/basic-usage",
        "core-concepts/agent-mode",
        "core-concepts/coder-mode",
        "core-concepts/context-commands"
      ]
    },
    {
      "group": "Funcionalidades",
      "pages": [
        {
          "group": "IA e Agentes",
          "pages": [
            "features/native-tool-use",
            "features/agentic-plugins",
            "features/multi-agent-orchestration",
            "features/customizable-agents"
          ]
        },
        {
          "group": "Coder",
          "pages": [
            "features/coder-plugin",
            "features/coder-security"
          ]
        },
        {
          "group": "Infraestrutura e DevOps",
          "pages": [
            "features/k8s-watcher",
            "features/k8s-operator",
            "features/aiops-platform",
            "features/server-mode",
            "features/remote-connect"
          ]
        },
        {
          "group": "Sessões e Contexto",
          "pages": [
            "features/session-management",
            "features/persistent-context",
            "features/bootstrap-memory"
          ]
        },
        {
          "group": "Integrações e Extensões",
          "pages": [
            "features/mcp-integration",
            "features/skill-registry",
            "features/oauth-authentication",
            "features/provider-fallback"
          ]
        },
        {
          "group": "Avançado",
          "pages": [
            "features/non-interactive-mode",
            "features/config-migration",
            "features/security"
          ]
        }
      ]
    },
    {
      "group": "Referência",
      "pages": [
        "reference/command-reference",
        "reference/configuration",
        "reference/supported-models"
      ]
    },
    {
      "group": "Suporte",
      "pages": [
        "support/troubleshooting"
      ]
    },
    {
      "group": "Cookbook",
      "pages": [
        "cookbook/agent-refactoring",
        "cookbook/coder-fix-tests",
        "cookbook/debugging-logs-with-pipes",
        "cookbook/k8s-monitoring",
        "cookbook/multi-project-workflow",
        "cookbook/onboarding-new-project",
        "cookbook/release-notes-automation",
        "cookbook/remote-server-setup"
      ]
    }
  ],
  "footerSocials": {
    "github": "https://github.com/diillson/chatcli"
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "search": {
    "prompt": "Buscar na documentação..."
  }
}
