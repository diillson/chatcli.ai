{
  "$schema": "https://mintlify.com/schema.json",
  "theme": "mint",
  "name": "ChatCLI",
  "logo": {
    "dark": "/images/logo-dark.svg",
    "light": "/images/logo-light.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1E40AF"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/diillson/chatcli"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install",
      "href": "https://github.com/diillson/chatcli/releases"
    }
  },
  "navigation": {
