    "links": [
      {
        "label": "Documentation",
        "href": "/introduction"
      },
      {
        "label": "Releases",
        "href": "https://github.com/diillson/chatcli/releases"
      },
      {
        "type": "github",
        "href": "https://github.com/diillson/chatcli"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install",
      "href": "/getting-started/installation"
    }
  },
