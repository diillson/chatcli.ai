          "href": "https://github.com/diillson/chatcli"
        },
        {
          "anchor": "Releases",
          "icon": "rocket",
          "href": "https://github.com/diillson/chatcli/releases"
        },
        {
          "anchor": "Issues",
          "icon": "bug",
          "href": "https://github.com/diillson/chatcli/issues"
        }
      ]
