{
  "$schema": "https://mintlify.com/schema.json",
  "theme": "mint",
  "name": "ChatCLI",
  "description": "Official ChatCLI documentation — a multi-provider AI CLI with agent mode, gRPC server and Kubernetes operator.",
  "logo": {
    "dark": "/images/logo-dark.svg",
    "light": "/images/logo-light.svg",
    "href": "/"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1E40AF"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "system"
  },
  "background": {
    "decoration": "gradient"
  },
  "interaction": {
    "drilldown": true
  },
  "api": {
    "openapi": "api-reference/openapi.json",
    "playground": {
      "display": "interactive"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "banner": {
    "content": "🚀 ChatCLI 1.153.0 — [Release notes »](https://github.com/diillson/chatcli/releases)",
    "dismissible": true
  },
